# ============================================================
# NineOS Backend — Environment Variables
# Salin file ini ke .env lalu isi nilainya
# JANGAN commit .env ke git
# ============================================================

# Database (PostgreSQL)
DATABASE_URL="postgresql://nineos:nineos_pass@localhost:5432/nineos_db?schema=public"

# API Gateway auth token — generate dengan: openssl rand -hex 32
GATEWAY_TOKEN="ganti_dengan_token_random_minimal_32_karakter"

# Enkripsi kredensial AES-256-GCM — generate dengan: openssl rand -hex 32
ENCRYPTION_KEY="ganti_dengan_hex_string_64_karakter"

# Port aplikasi
PORT=3000

# Environment
NODE_ENV=development
